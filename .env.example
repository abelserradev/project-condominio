PORT=3001
# MongoDB Local - Para servidor local usar: mongodb://localhost:27017/condominio
# MongoDB Atlas - Para cloud usar: mongodb+srv://user:password@cluster.mongodb.net/database
# MongoDB Docker - Para docker-compose usar: mongodb://mongodb:27017/condominio
MONGODB_URI=mongodb://localhost:27017/condominio
FRONTEND_URL=http://localhost:3000
ADMIN_USUARIO=tu_usuario_admin
ADMIN_PASSWORD=tu_contraseña_segura
JWT_SECRET=genera_una_cadena_aleatoria_segura_aqui
SEED_ADMIN=true
# ADMIN_RESET_PASSWORD=true  # Descomentar para forzar reset de contraseña al iniciar
