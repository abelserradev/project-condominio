# Backend Condominio - Variables de entorno
# Copiar a .env y completar valores. NO subir .env a Git.

PORT=3001
NODE_ENV=production

# MongoDB (Coolify: mongodb://mongodb:27017/condominio)
MONGODB_URI=mongodb://mongodb:27017/condominio

# URL del frontend en producción (Coolify + Cloudflare)
FRONTEND_URL=https://buildforge.work

# JWT - generar uno seguro: openssl rand -base64 32
JWT_SECRET=

# Admin inicial (seed)
ADMIN_USUARIO=Condominio
ADMIN_PASSWORD=
SEED_ADMIN=true
